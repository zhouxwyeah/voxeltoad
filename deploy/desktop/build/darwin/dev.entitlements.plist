<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Dev build entitlements. App Sandbox is OFF for local dev (the desktop
	     gateway needs to bind arbitrary local ports + read a YAML config + write
	     a SQLite file in user-chosen locations, which App Sandbox makes painful).
	     For a notarized distribution build, switch to a sandbox-friendly entitlements
	     set + hardened runtime. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
