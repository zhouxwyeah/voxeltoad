# Control Panel (web) — local environment
# Copy to .env.local and fill in. .env* is gitignored.

# Admin plane base URL. Local dev: run `make adminstack` (embedded PG + admin
# on 127.0.0.1:8090) or point at a real admin server.
ADMIN_URL=http://127.0.0.1:8090

# Secret used to encrypt the session cookie (iron-session). MUST be >= 32 chars.
# Generate one, e.g.: openssl rand -base64 32
SESSION_SECRET=dev-only-change-me-min-32-characters-long
